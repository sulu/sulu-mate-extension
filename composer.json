{
    "name": "sulu/sulu-mate-extension",
    "description": "Sulu AI Mate extension for the Sulu CMS",
    "type": "symfony-ai-mate",
    "license": "MIT",
    "keywords": ["sulu", "cms", "ai", "mate", "mcp", "ai-assistant"],
    "homepage": "https://github.com/sulu/sulu-mate-extension",
    "authors": [
        {
            "name": "Sulu Mate Extension Contributors",
            "homepage": "https://github.com/sulu/sulu-mate-extension/contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/sulu/sulu-mate-extension/issues",
        "source": "https://github.com/sulu/sulu-mate-extension"
    },
    "require": {
        "php": ">=8.2",
        "ext-simplexml": "*",
        "sulu/sulu": "^2.6 || ^3.0",
        "symfony/ai-mate": "^0.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Sulu\\MateExtension\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sulu\\MateExtension\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ai-mate": {
            "scan-dirs": [
                "src/Capability"
            ],
            "includes": ["config/config.php"],
            "instructions": "INSTRUCTIONS.md"
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": [
            "@composer validate --strict",
            "vendor/bin/rector process --dry-run",
            "vendor/bin/php-cs-fixer fix --dry-run --diff",
            "vendor/bin/phpstan analyse || test $? -eq 1 && echo 'PHPStan: no files to analyse, skipping'"
        ],
        "fix": [
            "vendor/bin/rector process",
            "vendor/bin/php-cs-fixer fix"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
